flowchart TB
    subgraph Input
        input[/"Input Image\n(B, 3, H, W)"/]
    end

    subgraph Encoder
        conv1["Conv2D\n3×3, pad=1\n3→32"]
        relu1(("ReLU"))
        
        subgraph "Spatial Attention Module"
            direction LR
            avgpool["Average\nPooling"]
            maxpool["Max\nPooling"]
            concat1{"Concat"}
            att_conv["Conv2D\n7×7, pad=3\n2→1"]
            sigmoid["Sigmoid"]
            mult((×))
            
            avgpool --> concat1
            maxpool --> concat1
            concat1 --> att_conv
            att_conv --> sigmoid
            sigmoid --> mult
        end
        
        pool1["MaxPool2D\n2×2"]
        conv2["Conv2D\n3×3, dilation=2\n32→32"]
        relu2(("ReLU"))
        pool2["MaxPool2D\n2×2"]
        conv3["Conv2D\n3×3, dilation=3\n32→32"]
        relu3(("ReLU"))
        pool3["MaxPool2D\n2×2"]
        conv4["Conv2D\n3×3, pad=1\n32→32"]
        relu4(("ReLU"))
    end

    subgraph Decoder
        unpool3["MaxUnpool2D\n2×2"]
        concat2{"Concat"}
        conv5["Conv2D\n3×3, pad=1\n64→32"]
        relu5(("ReLU"))
        
        unpool2["MaxUnpool2D\n2×2"]
        concat3{"Concat"}
        conv6["Conv2D\n3×3, pad=1\n64→32"]
        relu6(("ReLU"))
        
        unpool1["MaxUnpool2D\n2×2"]
        concat4{"Concat"}
        conv7["Conv2D\n3×3, pad=1\n64→24"]
        tanh(("tanh"))
    end

    subgraph "Enhancement Module"
        split["Split into 8\n3-channel curves"]
        enhance1["Enhance 1\nx + r1*(x²-x)"]
        enhance2["Enhance 2\nx + r2*(x²-x)"]
        enhance3["..."]
        enhance4["Enhance 8\nx + r8*(x²-x)"]
        clamp["Clamp\n[1e-7, 1.0]"]
    end

    subgraph "Gamma Correction"
        gamma["Adaptive γ\n0.5 + sigmoid(γ)"]
        power((^))
    end

    subgraph Output
        out[/"Enhanced Image\n+ Enhancement Curves"/]
    end

    %% Main flow
    input --> conv1
    conv1 --> relu1
    relu1 --> mult
    mult --> pool1
    pool1 --> conv2
    conv2 --> relu2
    relu2 --> pool2
    pool2 --> conv3
    conv3 --> relu3
    relu3 --> pool3
    pool3 --> conv4
    conv4 --> relu4
    
    %% Decoder flow
    relu4 --> unpool3
    unpool3 --> concat2
    relu3 --> concat2
    concat2 --> conv5
    conv5 --> relu5
    
    relu5 --> unpool2
    unpool2 --> concat3
    relu2 --> concat3
    concat3 --> conv6
    conv6 --> relu6
    
    relu6 --> unpool1
    unpool1 --> concat4
    relu1 --> concat4
    concat4 --> conv7
    conv7 --> tanh
    
    %% Enhancement flow
    tanh --> split
    split --> enhance1
    enhance1 --> enhance2
    enhance2 --> enhance3
    enhance3 --> enhance4
    enhance4 --> clamp
    
    %% Gamma correction
    clamp --> power
    gamma --> power
    
    power --> out

    %% Styling
    classDef conv fill:#e1f5fe,stroke:#01579b
    classDef pool fill:#fff3e0,stroke:#ff6f00
    classDef activation fill:#f1f8e9,stroke:#33691e
    classDef concat fill:#fce4ec,stroke:#880e4f
    classDef module fill:#f3e5f5,stroke:#4a148c
    
    class conv1,conv2,conv3,conv4,conv5,conv6,conv7,att_conv conv
    class pool1,pool2,pool3,unpool1,unpool2,unpool3 pool
    class relu1,relu2,relu3,relu4,relu5,relu6,tanh,sigmoid activation
    class concat1,concat2,concat3,concat4 concat
    class enhance1,enhance2,enhance3,enhance4,gamma module
